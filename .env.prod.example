# Production env for the Food Assistant service.
# Copy to `.env` on the server at the deploy path (NOT committed). CI requires
# this file to exist there before it can `docker compose up`.

# --- LLM provider (OpenRouter, OpenAI-compatible) ---------------------------
LLM_PROVIDER=openai-compatible
LLM_API_KEY=                         # OpenRouter key (sk-or-...). Keep it secret.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_VISION_MODEL=openai/gpt-4o-mini
LLM_DEFAULT_LANGUAGE=ru

# --- Service auth (service-to-service) --------------------------------------
# Required in production. The Telegram bot must send the same value as
# `Authorization: Bearer <token>` (bot's FOOD_SERVICE_TOKEN).
SERVICE_TOKEN=

# --- Runtime ----------------------------------------------------------------
PORT=3000
# DB_PATH is set to /data/food-assistant.sqlite by the image (mounted volume).
