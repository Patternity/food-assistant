# Copy to .env and fill in.

# --- LLM provider (provider-agnostic) ---------------------------------------
# The prototype talks to any OpenAI-compatible endpoint (direct OpenAI, or an
# aggregator/gateway). The provider is pluggable; today only "openai-compatible"
# is implemented, other providers can be added under src/llm/.
LLM_PROVIDER=openai-compatible

# API key for the provider / aggregator.
LLM_API_KEY=sk-...

# Base URL. Point it at your aggregator/gateway, or OpenAI directly.
LLM_BASE_URL=https://api.openai.com/v1

# Text/reasoning model. Must support vision if you use image analysis.
LLM_MODEL=gpt-4o-mini

# Optional separate model for image extraction (defaults to LLM_MODEL).
# LLM_VISION_MODEL=gpt-4o-mini

# --- Server -----------------------------------------------------------------
PORT=3000

# --- Auth (service-to-service) ----------------------------------------------
# SERVICE_TOKEN protects /api (except /api/health). It authenticates the CALLER
# (e.g. the Telegram bot backend), NOT the end user. Leave UNSET for local dev
# (open on localhost) — do NOT put a token in browser JS. Set it before exposing
# the service; the trusted caller then sends `Authorization: Bearer <token>` (or
# `X-Api-Key`) plus `X-User-Id: <telegram id>` on every request.
# SERVICE_TOKEN=change-me-to-a-long-random-secret

# Optional: separate SQLite path (tests should use an isolated file, e.g. /tmp).
# DB_PATH=./data/food-assistant.sqlite

# Cap on output tokens per LLM call (default 2048). Prevents gateways from
# reserving the full model max (some free tiers 402 otherwise).
# LLM_MAX_TOKENS=2048

# --- Token budgets (abuse guard) --------------------------------------------
# Cumulative LLM tokens allowed per session and per user per day. At WARN_RATIO
# of either, the assistant warns the user and adds a session summary but keeps
# answering; at 100% the service hard-stops (a canned message, no LLM call)
# until a new session / the next day. Set to 0 to disable a limit.
# SESSION_TOKEN_BUDGET=20000
# DAILY_TOKEN_BUDGET=100000
# TOKEN_WARN_RATIO=0.8
